---
import { getCollection } from 'astro:content';

const now = new Date();
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.publishedAt <= now)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Brutalist — Design Demo</title>
  <meta name="robots" content="noindex" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap');

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #ffffff;
      --fg: #000000;
      --accent: #6366f1;
      --muted: rgba(0,0,0,0.4);
      --border: #000000;
    }

    body {
      font-family: 'Space Mono', monospace;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.5;
    }

    a { color: inherit; text-decoration: none; }

    /* Back link */
    .back-link {
      position: fixed;
      top: 1rem;
      left: 1rem;
      z-index: 100;
      padding: 0.5rem 1rem;
      border: 2px solid var(--border);
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      background: var(--bg);
      transition: all 0.15s;
    }
    .back-link:hover {
      background: var(--accent);
      border-color: var(--accent);
      color: white;
    }

    /* Hero */
    .hero {
      border-bottom: 4px solid var(--border);
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 80vh;
    }
    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; }
    }

    .hero-text {
      padding: 4rem 3rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-right: 4px solid var(--border);
    }
    @media (max-width: 768px) {
      .hero-text { border-right: none; border-bottom: 4px solid var(--border); padding: 3rem 1.5rem; }
    }

    .hero-label {
      display: inline-block;
      border: 2px solid var(--border);
      padding: 0.3rem 0.8rem;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.25em;
      margin-bottom: 2rem;
    }

    .hero h1 {
      font-size: clamp(3rem, 8vw, 7rem);
      font-weight: 700;
      line-height: 0.85;
      text-transform: uppercase;
      letter-spacing: -0.02em;
    }
    .hero h1 span { color: var(--accent); }

    .hero-desc {
      margin-top: 2rem;
      max-width: 28rem;
      font-size: 0.8rem;
      line-height: 1.7;
      color: var(--muted);
    }

    .hero-cta {
      display: inline-block;
      margin-top: 2.5rem;
      padding: 1rem 2.5rem;
      border: 2px solid var(--border);
      background: var(--fg);
      color: var(--bg);
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      transition: all 0.15s;
    }
    .hero-cta:hover {
      background: var(--accent);
      border-color: var(--accent);
    }

    .hero-visual {
      background: var(--accent);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .hero-visual::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 30px, rgba(0,0,0,0.08) 30px, rgba(0,0,0,0.08) 31px),
        repeating-linear-gradient(90deg, transparent, transparent 30px, rgba(0,0,0,0.08) 30px, rgba(0,0,0,0.08) 31px);
    }
    .hero-number {
      position: relative;
      font-size: clamp(10rem, 25vw, 20rem);
      font-weight: 700;
      color: rgba(255,255,255,0.15);
      line-height: 1;
    }

    /* Section header */
    .section-header {
      border-bottom: 2px solid var(--border);
      padding: 1.5rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .section-header h2 {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.25em;
    }
    .section-header .count {
      font-size: 0.65rem;
      color: var(--muted);
    }

    /* Post grid */
    .post-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }

    .post-card {
      padding: 2rem;
      border-bottom: 2px solid var(--border);
      border-right: 2px solid var(--border);
      transition: all 0.15s;
      position: relative;
    }
    .post-card:hover {
      background: var(--accent);
      color: white;
    }
    .post-card:hover .post-num,
    .post-card:hover .post-date,
    .post-card:hover .post-desc,
    .post-card:hover .post-tag {
      color: rgba(255,255,255,0.7);
    }
    .post-card:hover .post-tag {
      border-color: rgba(255,255,255,0.4);
    }

    .post-num {
      font-size: 2.5rem;
      font-weight: 700;
      color: rgba(0,0,0,0.08);
      line-height: 1;
      margin-bottom: 0.75rem;
    }

    .post-date {
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--muted);
    }

    .post-title {
      margin-top: 0.5rem;
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      line-height: 1.3;
    }

    .post-desc {
      margin-top: 0.5rem;
      font-size: 0.7rem;
      line-height: 1.6;
      color: var(--muted);
    }

    .post-tags {
      margin-top: 1rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .post-tag {
      border: 1px solid rgba(0,0,0,0.15);
      padding: 0.15rem 0.5rem;
      font-size: 0.55rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--muted);
    }

    /* Footer */
    .footer {
      border-top: 4px solid var(--border);
      padding: 3rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--muted);
    }
    @media (max-width: 768px) {
      .footer { flex-direction: column; gap: 1rem; text-align: center; }
    }
  </style>
</head>
<body>

  <a href="/demo/" class="back-link">&larr; All Demos</a>

  <!-- Hero -->
  <div class="hero">
    <div class="hero-text">
      <div class="hero-label">Est. 2026</div>
      <h1>AI<br/>Shop<br/>Blue<span>print</span></h1>
      <p class="hero-desc">
        No fluff. No hype. Just raw, actionable AI strategies for Etsy sellers and POD entrepreneurs who want results.
      </p>
      <a href="#posts" class="hero-cta">Read Articles &rarr;</a>
    </div>
    <div class="hero-visual">
      <div class="hero-number">01</div>
    </div>
  </div>

  <!-- Posts -->
  <div id="posts">
    <div class="section-header">
      <h2>All Articles</h2>
      <span class="count">{posts.length} entries</span>
    </div>
    <div class="post-grid">
      {posts.map((post, i) => (
        <a href={`/blog/${post.id}/`} class="post-card">
          <div class="post-num">{String(i + 1).padStart(2, '0')}</div>
          <div class="post-date">
            {post.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </div>
          <div class="post-title">{post.data.title}</div>
          <div class="post-desc">{post.data.description}</div>
          <div class="post-tags">
            {post.data.tags?.map((tag) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Footer -->
  <div class="footer">
    <span>&copy; 2026 AI Shop Blueprint</span>
    <span>Brutalist Edition</span>
  </div>

</body>
</html>
