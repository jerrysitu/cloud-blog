---
import { getCollection } from 'astro:content';

const now = new Date();
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.publishedAt <= now)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Retro Terminal вЂ” Design Demo</title>
  <meta name="robots" content="noindex" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap');

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0d0a00;
      --fg: #fbbf24;
      --fg-dim: rgba(251,191,36,0.4);
      --fg-bright: #fde68a;
      --glow: rgba(251,191,36,0.3);
      --scanline: rgba(0,0,0,0.15);
    }

    body {
      font-family: 'JetBrains Mono', 'Courier New', monospace;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.6;
      position: relative;
    }

    /* CRT scanlines */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9999;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        var(--scanline) 2px,
        var(--scanline) 4px
      );
      opacity: 0.4;
    }

    /* CRT vignette */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9998;
      background: radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.5) 100%);
    }

    a { color: inherit; text-decoration: none; }

    .back-link {
      position: fixed;
      top: 1rem;
      left: 1rem;
      z-index: 10000;
      padding: 0.4rem 0.8rem;
      font-size: 0.7rem;
      border: 1px solid var(--fg-dim);
      color: var(--fg);
      transition: all 0.15s;
    }
    .back-link:hover {
      background: var(--fg);
      color: var(--bg);
    }

    /* Boot screen */
    .boot {
      padding: 3rem 2rem 1rem;
      max-width: 56rem;
      margin: 0 auto;
      font-size: 0.8rem;
      color: var(--fg-dim);
    }
    .boot .line { margin-bottom: 0.2rem; }
    .boot .ok { color: var(--fg); }

    /* Hero */
    .hero {
      max-width: 56rem;
      margin: 0 auto;
      padding: 2rem 2rem 3rem;
    }
    .hero-ascii {
      color: var(--fg);
      font-size: clamp(0.5rem, 1.8vw, 1rem);
      line-height: 1.2;
      text-shadow: 0 0 20px var(--glow);
      white-space: pre;
      overflow-x: auto;
    }
    .hero-desc {
      margin-top: 2rem;
      font-size: 0.8rem;
      color: var(--fg-dim);
      max-width: 40rem;
      line-height: 1.7;
    }
    .hero-desc .prompt { color: var(--fg); }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1.5rem;
      padding: 0.6rem 1.5rem;
      border: 1px solid var(--fg-dim);
      font-size: 0.8rem;
      color: var(--fg);
      background: rgba(251,191,36,0.03);
      transition: all 0.15s;
    }
    .hero-cta:hover {
      background: rgba(251,191,36,0.1);
      border-color: var(--fg);
      text-shadow: 0 0 10px var(--glow);
    }

    /* Divider */
    .divider {
      max-width: 56rem;
      margin: 0 auto;
      padding: 0 2rem;
      font-size: 0.7rem;
      color: var(--fg-dim);
      opacity: 0.5;
    }
    .divider::before {
      content: 'в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ';
      display: block;
      overflow: hidden;
      white-space: nowrap;
    }

    /* Posts */
    .posts {
      max-width: 56rem;
      margin: 0 auto;
      padding: 1.5rem 2rem 4rem;
    }
    .posts-header {
      font-size: 0.75rem;
      color: var(--fg-dim);
      margin-bottom: 1rem;
    }
    .posts-header .cmd { color: var(--fg); }

    .posts-table-header {
      display: grid;
      grid-template-columns: 3rem 6rem 1fr;
      gap: 1rem;
      font-size: 0.65rem;
      font-weight: 700;
      color: var(--fg-dim);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid rgba(251,191,36,0.1);
      margin-bottom: 0.5rem;
    }

    .post-row {
      display: grid;
      grid-template-columns: 3rem 6rem 1fr;
      gap: 1rem;
      padding: 0.75rem 0.5rem;
      border-radius: 2px;
      transition: all 0.15s;
      border-bottom: 1px solid rgba(251,191,36,0.03);
    }
    .post-row:hover {
      background: rgba(251,191,36,0.05);
      border-color: rgba(251,191,36,0.1);
    }

    .post-idx {
      font-size: 0.75rem;
      color: var(--fg-dim);
      opacity: 0.5;
    }
    .post-date {
      font-size: 0.75rem;
      color: var(--fg-dim);
    }
    .post-info { min-width: 0; }
    .post-title-text {
      font-size: 0.8rem;
      color: var(--fg);
      transition: all 0.15s;
    }
    .post-row:hover .post-title-text {
      color: var(--fg-bright);
      text-shadow: 0 0 10px var(--glow);
    }
    .post-desc-text {
      font-size: 0.7rem;
      color: var(--fg-dim);
      margin-top: 0.2rem;
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .post-tags-text {
      font-size: 0.65rem;
      color: rgba(251,191,36,0.3);
      margin-top: 0.3rem;
    }

    /* Prompt */
    .prompt-line {
      max-width: 56rem;
      margin: 0 auto;
      padding: 0 2rem 4rem;
      font-size: 0.8rem;
      color: var(--fg-dim);
    }
    .cursor {
      display: inline-block;
      width: 0.5em;
      height: 1em;
      background: var(--fg);
      animation: blink 1s step-end infinite;
      vertical-align: text-bottom;
    }
    @keyframes blink {
      50% { opacity: 0; }
    }

    /* Footer */
    .footer {
      border-top: 1px solid rgba(251,191,36,0.1);
      max-width: 56rem;
      margin: 0 auto;
      padding: 1.5rem 2rem;
      display: flex;
      justify-content: space-between;
      font-size: 0.65rem;
      color: var(--fg-dim);
      opacity: 0.5;
    }
  </style>
</head>
<body>

  <a href="/demo/" class="back-link">&larr; BACK</a>

  <!-- Boot sequence -->
  <div class="boot">
    <div class="line">BIOS v4.2.6 вЂ” POST complete</div>
    <div class="line">MEM: 640K OK</div>
    <div class="line">Loading ai-shop-blueprint.sys... <span class="ok">OK</span></div>
    <div class="line">Mounting /articles/... <span class="ok">{posts.length} entries found</span></div>
    <div class="line">Ready.</div>
  </div>

  <!-- Hero -->
  <div class="hero">
    <div class="hero-ascii">
