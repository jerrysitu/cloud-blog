в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ</div>
    <div class="hero-desc">
      <span class="prompt">&gt;</span> Practical AI strategies for Etsy sellers and POD operators.<br/>
      <span class="prompt">&gt;</span> No GUI. No gimmicks. Just the signal.
    </div>
    <a href="#listing" class="hero-cta">
      <span style="opacity: 0.5">$</span> cat /articles/*
    </a>
  </div>

  <div class="divider"></div>

  <!-- Posts listing -->
  <div class="posts" id="listing">
    <div class="posts-header">
      <span class="cmd">$ ls -la /articles/ --sort=date --format=detailed</span>
    </div>

    <div class="posts-table-header">
      <span>idx</span>
      <span>date</span>
      <span>title</span>
    </div>

    {posts.map((post, i) => (
      <a href={`/blog/${post.id}/`} class="post-row">
        <span class="post-idx">[{String(i).padStart(2, '0')}]</span>
        <span class="post-date">
          {post.data.publishedAt.toLocaleDateString('en-US', { year: '2-digit', month: '2-digit', day: '2-digit' })}
        </span>
        <div class="post-info">
          <div class="post-title-text">{post.data.title}</div>
          <div class="post-desc-text">{post.data.description}</div>
          <div class="post-tags-text">
            {post.data.tags?.map(t => `#${t}`).join('  ')}
          </div>
        </div>
      </a>
    ))}
  </div>

  <div class="prompt-line">
    &gt; <span class="cursor"></span>
  </div>

  <div class="footer">
    <span>&copy; 2026 ai-shop-blueprint</span>
    <span>terminal v4.2.6</span>
  </div>

</body>
</html>
