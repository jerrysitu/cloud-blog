---
import { getCollection } from 'astro:content';

const now = new Date();
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.publishedAt <= now)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const featured = posts[0];
const rest = posts.slice(1);

function readTime(body: string | undefined): string {
  if (!body) return '1 min';
  return `${Math.max(1, Math.ceil(body.split(/\s+/).length / 200))} min`;
}
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Glassmorphic — Design Demo</title>
  <meta name="robots" content="noindex" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0f0b1e;
      --glass: rgba(255,255,255,0.04);
      --glass-border: rgba(255,255,255,0.08);
      --glass-hover: rgba(255,255,255,0.07);
      --fg: rgba(255,255,255,0.9);
      --fg-muted: rgba(255,255,255,0.4);
      --fg-dim: rgba(255,255,255,0.2);
      --accent: #7c3aed;
      --accent-light: #c4b5fd;
      --pink: #ec4899;
      --cyan: #06b6d4;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.6;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }

    .back-link {
      position: fixed;
      top: 1rem;
      left: 1rem;
      z-index: 100;
      padding: 0.5rem 1.2rem;
      border-radius: 1rem;
      font-size: 0.75rem;
      font-weight: 500;
      background: var(--glass);
      border: 1px solid var(--glass-border);
      backdrop-filter: blur(12px);
      color: var(--fg-muted);
      transition: all 0.2s;
    }
    .back-link:hover {
      background: var(--glass-hover);
      color: var(--fg);
      border-color: rgba(255,255,255,0.15);
    }

    /* Aurora blobs */
    .aurora {
      position: fixed;
      inset: 0;
      z-index: -1;
      overflow: hidden;
    }
    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(120px);
      animation: float 20s ease-in-out infinite;
    }
    .blob-1 {
      width: 600px; height: 600px;
      background: rgba(124,58,237,0.25);
      top: -200px; left: -200px;
      animation-delay: 0s;
    }
    .blob-2 {
      width: 400px; height: 400px;
      background: rgba(6,182,212,0.15);
      top: 30%; right: -100px;
      animation-delay: -7s;
    }
    .blob-3 {
      width: 500px; height: 500px;
      background: rgba(236,72,153,0.12);
      bottom: -100px; left: 30%;
      animation-delay: -14s;
    }
    .blob-4 {
      width: 300px; height: 300px;
      background: rgba(124,58,237,0.15);
      top: 60%; right: 20%;
      animation-delay: -3s;
    }
    @keyframes float {
      0%, 100% { transform: translate(0, 0) scale(1); }
      25% { transform: translate(30px, -30px) scale(1.05); }
      50% { transform: translate(-20px, 20px) scale(0.95); }
      75% { transform: translate(10px, -10px) scale(1.02); }
    }

    /* Hero */
    .hero {
      text-align: center;
      padding: 8rem 1.5rem 5rem;
      position: relative;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 1rem;
      border-radius: 9999px;
      border: 1px solid var(--glass-border);
      background: var(--glass);
      backdrop-filter: blur(12px);
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--fg-muted);
      margin-bottom: 2rem;
    }
    .hero-badge .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
    }
    .hero h1 {
      font-size: clamp(3rem, 8vw, 6rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.02em;
    }
    .hero h1 .line-1 {
      background: linear-gradient(to right, white, var(--accent-light), var(--accent));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero h1 .line-2 {
      background: linear-gradient(to right, var(--accent), var(--cyan), var(--pink));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero-desc {
      max-width: 28rem;
      margin: 1.5rem auto 0;
      font-size: 1rem;
      font-weight: 400;
      color: var(--fg-muted);
      line-height: 1.7;
    }
    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      margin-top: 2.5rem;
    }
    .btn-primary {
      padding: 0.85rem 2rem;
      border-radius: 1rem;
      font-size: 0.9rem;
      font-weight: 600;
      background: var(--accent);
      color: white;
      box-shadow: 0 8px 30px rgba(124,58,237,0.3);
      transition: all 0.25s;
    }
    .btn-primary:hover {
      box-shadow: 0 12px 40px rgba(124,58,237,0.4);
      transform: translateY(-1px);
    }
    .btn-secondary {
      padding: 0.85rem 2rem;
      border-radius: 1rem;
      font-size: 0.9rem;
      font-weight: 500;
      background: var(--glass);
      border: 1px solid var(--glass-border);
      backdrop-filter: blur(12px);
      color: var(--fg-muted);
      transition: all 0.25s;
    }
    .btn-secondary:hover {
      background: var(--glass-hover);
      color: var(--fg);
      border-color: rgba(255,255,255,0.15);
    }

    /* Content */
    .content {
      max-width: 64rem;
      margin: 0 auto;
      padding: 0 1.5rem 6rem;
    }

    /* Featured card */
    .featured {
      display: block;
      padding: 2.5rem;
      border-radius: 1.5rem;
      border: 1px solid var(--glass-border);
      background: var(--glass);
      backdrop-filter: blur(16px);
      margin-bottom: 2rem;
      transition: all 0.3s;
      box-shadow: inset 0 -80px 100px -80px rgba(124,58,237,0.06);
    }
    .featured:hover {
      border-color: rgba(255,255,255,0.15);
      background: var(--glass-hover);
    }
    .featured-label {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      background: rgba(124,58,237,0.25);
      color: var(--accent-light);
      margin-bottom: 1rem;
    }
    .featured-meta {
      font-size: 0.8rem;
      color: var(--fg-dim);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }
    .featured-meta .sep {
      width: 3px; height: 3px;
      border-radius: 50%;
      background: var(--fg-dim);
    }
    .featured h2 {
      font-size: 1.75rem;
      font-weight: 700;
      line-height: 1.2;
      color: var(--fg);
      transition: color 0.2s;
    }
    .featured:hover h2 { color: white; }
    .featured .desc {
      margin-top: 0.75rem;
      color: var(--fg-muted);
      max-width: 36rem;
      line-height: 1.6;
    }
    .featured .tags {
      margin-top: 1.25rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .glass-tag {
      padding: 0.2rem 0.65rem;
      border-radius: 9999px;
      font-size: 0.7rem;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      color: var(--fg-muted);
    }
    .featured-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--accent-light);
      transition: gap 0.2s;
    }
    .featured:hover .featured-cta { gap: 0.75rem; }

    /* Grid */
    .post-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1rem;
    }
    .post-card {
      padding: 1.75rem;
      border-radius: 1.25rem;
      border: 1px solid var(--glass-border);
      background: var(--glass);
      backdrop-filter: blur(12px);
      transition: all 0.25s;
    }
    .post-card:hover {
      border-color: rgba(124,58,237,0.25);
      background: var(--glass-hover);
      transform: translateY(-2px);
    }
    .post-card-date {
      font-size: 0.75rem;
      color: var(--fg-dim);
    }
    .post-card-title {
      font-size: 1.05rem;
      font-weight: 600;
      line-height: 1.3;
      margin-top: 0.5rem;
      color: rgba(255,255,255,0.8);
      transition: color 0.2s;
    }
    .post-card:hover .post-card-title { color: white; }
    .post-card-desc {
      font-size: 0.8rem;
      color: var(--fg-muted);
      margin-top: 0.5rem;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .post-card-tags {
      margin-top: 1rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .post-card-meta {
      margin-top: 0.75rem;
      font-size: 0.7rem;
      color: var(--fg-dim);
    }

    /* Footer */
    .footer {
      border-top: 1px solid var(--glass-border);
      text-align: center;
      padding: 2.5rem 1.5rem;
      font-size: 0.8rem;
      color: var(--fg-dim);
    }
    .footer-star {
      color: var(--accent-light);
    }
  </style>
</head>
<body>

  <!-- Aurora background -->
  <div class="aurora">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
  </div>

  <a href="/demo/" class="back-link">&larr; All Demos</a>

  <!-- Hero -->
  <div class="hero">
    <div class="hero-badge">
      <span class="dot"></span>
      AI-Powered Ecommerce
    </div>
    <h1>
      <span class="line-1">AI Shop</span><br/>
      <span class="line-2">Blueprint</span>
    </h1>
    <p class="hero-desc">
      Strategies for Etsy sellers and POD entrepreneurs. AI tools, prompts, and workflows — beautifully explained.
    </p>
    <div class="hero-actions">
      <a href="#posts" class="btn-primary">Browse Articles</a>
      <a href="/rss.xml" class="btn-secondary">Subscribe</a>
    </div>
  </div>

  <!-- Posts -->
  <div class="content" id="posts">
    <!-- Featured -->
    {featured && (
      <a href={`/blog/${featured.id}/`} class="featured">
        <span class="featured-label">Featured</span>
        <div class="featured-meta">
          <time>{featured.data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
          <span class="sep"></span>
          <span>{readTime(featured.body)} read</span>
        </div>
        <h2>{featured.data.title}</h2>
        <p class="desc">{featured.data.description}</p>
        <div class="tags">
          {featured.data.tags?.map((tag) => (
            <span class="glass-tag">{tag}</span>
          ))}
        </div>
        <div class="featured-cta">
          Read article
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </div>
      </a>
    )}

    <!-- Grid -->
    <div class="post-grid">
      {rest.map((post) => (
        <a href={`/blog/${post.id}/`} class="post-card">
          <div class="post-card-date">
            {post.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </div>
          <div class="post-card-title">{post.data.title}</div>
          <div class="post-card-desc">{post.data.description}</div>
          <div class="post-card-tags">
            {post.data.tags?.slice(0, 3).map((tag) => (
              <span class="glass-tag">{tag}</span>
            ))}
          </div>
          <div class="post-card-meta">{readTime(post.body)} read</div>
        </a>
      ))}
    </div>
  </div>

  <div class="footer">
    &copy; 2026 AI Shop Blueprint &middot; Built with <span class="footer-star">&#9733;</span> Astro
  </div>

</body>
</html>
