---
import { getCollection } from 'astro:content';

const now = new Date();
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.publishedAt <= now)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const featured = posts[0];
const rest = posts.slice(1);
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Organic — Design Demo</title>
  <meta name="robots" content="noindex" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@400;500&display=swap');

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #faf7f2;
      --bg-card: rgba(255,255,255,0.6);
      --fg: #3d3525;
      --fg-muted: #8b7e6a;
      --accent: #059669;
      --accent-light: #d1fae5;
      --border: #d4c9b8;
      --serif: 'Lora', Georgia, serif;
      --sans: 'DM Sans', sans-serif;
    }

    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--fg);
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }

    .back-link {
      position: fixed;
      top: 1rem;
      left: 1rem;
      z-index: 100;
      padding: 0.5rem 1.2rem;
      border-radius: 9999px;
      font-family: var(--sans);
      font-size: 0.75rem;
      font-weight: 500;
      background: var(--fg);
      color: var(--bg);
      transition: all 0.2s;
    }
    .back-link:hover { background: var(--accent); }

    /* Hero */
    .hero {
      position: relative;
      overflow: hidden;
      text-align: center;
      padding: 8rem 1.5rem 6rem;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -100px;
      left: -100px;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(5,150,105,0.08), transparent 70%);
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: -80px;
      right: -80px;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(212,201,184,0.4), transparent 70%);
    }

    .hero-divider {
      width: 3rem;
      height: 1px;
      background: var(--fg-muted);
      opacity: 0.3;
      margin: 0 auto 1.5rem;
    }
    .hero-eyebrow {
      font-family: var(--serif);
      font-size: 0.85rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--fg-muted);
      margin-bottom: 1rem;
    }
    .hero h1 {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      font-size: clamp(3rem, 7vw, 5.5rem);
      line-height: 1.1;
      color: var(--fg);
      position: relative;
    }
    .hero-desc {
      font-family: var(--serif);
      max-width: 30rem;
      margin: 1.5rem auto 0;
      font-size: 1rem;
      line-height: 1.7;
      color: var(--fg-muted);
    }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      margin-top: 2.5rem;
      padding: 0.9rem 2rem;
      border-radius: 9999px;
      font-family: var(--serif);
      font-size: 0.9rem;
      background: var(--fg);
      color: var(--bg);
      transition: all 0.25s;
    }
    .hero-cta:hover { background: var(--accent); }
    .hero-cta svg { width: 1rem; height: 1rem; }

    /* Content */
    .content {
      max-width: 52rem;
      margin: 0 auto;
      padding: 0 1.5rem 6rem;
    }

    /* Featured */
    .featured {
      display: block;
      padding: 2.5rem;
      border-radius: 1.5rem;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.5);
      margin-bottom: 3rem;
      transition: all 0.3s;
    }
    .featured:hover {
      box-shadow: 0 12px 40px rgba(61,53,37,0.08);
    }
    .featured-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.75rem;
      color: var(--fg-muted);
      letter-spacing: 0.1em;
      margin-bottom: 1rem;
    }
    .featured-badge .dot {
      width: 0.4rem;
      height: 0.4rem;
      border-radius: 50%;
      background: var(--accent);
    }
    .featured h2 {
      font-family: var(--serif);
      font-style: italic;
      font-size: 1.75rem;
      line-height: 1.25;
      color: var(--fg);
      transition: color 0.2s;
    }
    .featured:hover h2 { color: var(--accent); }
    .featured .desc {
      font-family: var(--serif);
      margin-top: 0.75rem;
      color: var(--fg-muted);
      font-size: 0.95rem;
      line-height: 1.6;
    }
    .featured .tags {
      margin-top: 1.25rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .featured .tag {
      font-family: var(--serif);
      font-size: 0.75rem;
      padding: 0.3rem 0.9rem;
      border-radius: 9999px;
      background: rgba(212,201,184,0.4);
      color: var(--fg-muted);
    }

    /* Posts */
    .posts-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .post-item {
      display: grid;
      grid-template-columns: 1.5rem 1fr;
      gap: 1rem;
      align-items: start;
      padding: 1.25rem 0;
      border-bottom: 1px solid rgba(212,201,184,0.4);
      transition: all 0.2s;
    }
    .post-item:last-child {
      border-bottom: none;
    }
    .post-item:hover {
      background: none;
    }
    .post-dot {
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 50%;
      background: rgba(5,150,105,0.25);
      margin-top: 0.5rem;
      justify-self: center;
      transition: all 0.2s;
    }
    .post-item:hover .post-dot {
      background: var(--accent);
      box-shadow: 0 0 8px rgba(5,150,105,0.3);
    }
    .post-date {
      font-family: var(--serif);
      font-size: 0.75rem;
      color: var(--fg-muted);
      letter-spacing: 0.05em;
    }
    .post-title {
      font-family: var(--serif);
      font-size: 1.1rem;
      line-height: 1.3;
      margin-top: 0.2rem;
      transition: color 0.2s;
    }
    .post-item:hover .post-title { color: var(--accent); }
    .post-desc {
      font-family: var(--serif);
      font-size: 0.85rem;
      color: var(--fg-muted);
      margin-top: 0.3rem;
      opacity: 0.7;
    }
    .post-tags-inline {
      display: flex;
      gap: 0.5rem;
      margin-top: 0.5rem;
      flex-wrap: wrap;
    }
    .post-tags-inline span {
      font-size: 0.65rem;
      color: var(--accent);
      opacity: 0.6;
    }

    /* Footer */
    .footer {
      border-top: 1px solid var(--border);
      padding: 3rem 1.5rem;
      text-align: center;
      font-family: var(--serif);
      font-size: 0.8rem;
      color: var(--fg-muted);
    }
  </style>
</head>
<body>

  <a href="/demo/" class="back-link">&larr; All Demos</a>

  <div class="hero">
    <div class="hero-divider"></div>
    <div class="hero-eyebrow">where craft meets code</div>
    <h1>AI Shop<br/>Blueprint</h1>
    <p class="hero-desc">
      Gentle guidance for artisans embracing AI — written for makers, by makers.
      Grow your Etsy &amp; Print-on-Demand shop with intention.
    </p>
    <a href="#posts" class="hero-cta">
      Explore articles
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
    </a>
  </div>

  <div class="content" id="posts">
    {featured && (
      <a href={`/blog/${featured.id}/`} class="featured">
        <div class="featured-badge">
          <span class="dot"></span>
          <time>{featured.data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
        </div>
        <h2>{featured.data.title}</h2>
        <p class="desc">{featured.data.description}</p>
        <div class="tags">
          {featured.data.tags?.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </a>
    )}

    <div class="posts-list">
      {rest.map((post) => (
        <a href={`/blog/${post.id}/`} class="post-item">
          <div class="post-dot"></div>
          <div>
            <div class="post-date">
              {post.data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </div>
            <div class="post-title">{post.data.title}</div>
            <div class="post-desc">{post.data.description}</div>
            <div class="post-tags-inline">
              {post.data.tags?.map((tag) => (
                <span>#{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="footer">
    &copy; 2026 AI Shop Blueprint &middot; Organic Edition
  </div>

</body>
</html>
