---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Design Variations - AI Shop Blueprint"
  description="Five unique frontend design variations."
  noindex={true}
>
  <div class="mx-auto max-w-3xl px-4 py-20 sm:px-6">
    <h1 class="font-display text-4xl tracking-tight text-gray-900 dark:text-white sm:text-5xl">
      Design <span class="text-[var(--color-accent)]">Variations</span>
    </h1>
    <p class="mt-4 text-gray-500 dark:text-gray-400">
      Five completely different frontends, same content. Each is a full standalone page.
    </p>

    <div class="mt-12 grid gap-4">
      <a href="/demo/v1/" class="group flex items-center gap-6 rounded-2xl border border-black/10 bg-white p-6 transition-all hover:shadow-lg dark:border-white/10 dark:bg-white/5 dark:hover:border-white/20">
        <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-black font-mono text-lg font-black text-white dark:bg-white dark:text-black">01</div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Brutalist</h2>
          <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">Raw, monospace, no curves. Black & white with aggressive typography and hard grid layouts.</p>
        </div>
      </a>

      <a href="/demo/v2/" class="group flex items-center gap-6 rounded-2xl border border-black/10 bg-white p-6 transition-all hover:shadow-lg dark:border-white/10 dark:bg-white/5 dark:hover:border-white/20">
        <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-[#3d3525] text-lg font-light italic text-[#faf7f2] dark:bg-[#e8e0cc] dark:text-[#3d3525]" style="font-family: Georgia, serif;">02</div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Organic</h2>
          <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">Warm, earthy, serif typography. Cream backgrounds with botanical softness and gentle motion.</p>
        </div>
      </a>

      <a href="/demo/v3/" class="group flex items-center gap-6 rounded-2xl border border-black/10 bg-white p-6 transition-all hover:shadow-lg dark:border-white/10 dark:bg-white/5 dark:hover:border-white/20">
        <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-[#e11d48] text-lg font-extralight text-white" style="font-family: Georgia, serif;">03</div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Magazine</h2>
          <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">Editorial layout with asymmetric grids, large serif headlines, and magazine-cover aesthetics.</p>
        </div>
      </a>

      <a href="/demo/v4/" class="group flex items-center gap-6 rounded-2xl border border-black/10 bg-white p-6 transition-all hover:shadow-lg dark:border-white/10 dark:bg-white/5 dark:hover:border-white/20">
        <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-[#1a1407] font-mono text-lg font-bold text-[#fbbf24]">04</div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Retro Terminal</h2>
          <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">Amber CRT aesthetics, monospace everything, scanlines, and command-line interaction patterns.</p>
        </div>
      </a>

      <a href="/demo/v5/" class="group flex items-center gap-6 rounded-2xl border border-black/10 bg-white p-6 transition-all hover:shadow-lg dark:border-white/10 dark:bg-white/5 dark:hover:border-white/20">
        <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-[#0f0b1e] text-lg font-bold text-[#c4b5fd]">05</div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Glassmorphic</h2>
          <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">Aurora blobs, frosted glass cards, gradient text, and deep purple-space vibes.</p>
        </div>
      </a>
    </div>
  </div>
</BaseLayout>
