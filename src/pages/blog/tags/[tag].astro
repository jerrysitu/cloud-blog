---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const now = new Date();
  const allPosts = await getCollection('blog');
  const posts = allPosts.filter((post) => post.data.publishedAt <= now);

  const tagMap = new Map<string, typeof posts>();
  posts.forEach((post) => {
    post.data.tags?.forEach((tag) => {
      const slug = tag.toLowerCase().replace(/\s+/g, '-');
      if (!tagMap.has(slug)) tagMap.set(slug, []);
      tagMap.get(slug)!.push(post);
    });
  });

  return Array.from(tagMap.entries()).map(([slug, tagPosts]) => ({
    params: { tag: slug },
    props: {
      tag: tagPosts[0]?.data.tags?.find(
        (t) => t.toLowerCase().replace(/\s+/g, '-') === slug,
      ) || slug,
      posts: tagPosts.sort(
        (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
      ),
    },
  }));
}

const { tag, posts } = Astro.props;

function readingTime(body: string | undefined): string {
  if (!body) return '1 min read';
  const words = body.split(/\s+/).length;
  const minutes = Math.max(1, Math.ceil(words / 200));
  return `${minutes} min read`;
}
---

<BaseLayout
  title={`Posts tagged "${tag}" - AI Shop Blueprint`}
  description={`Articles about ${tag} for Etsy sellers and Print-on-Demand entrepreneurs.`}
  currentPage="blog"
  noindex={true}
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 sm:py-16">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <li>
          <a href="/" class="hover:text-gray-900 dark:hover:text-white transition-colors">Home</a>
        </li>
        <li aria-hidden="true">/</li>
        <li>
          <a href="/blog" class="hover:text-gray-900 dark:hover:text-white transition-colors">Blog</a>
        </li>
        <li aria-hidden="true">/</li>
        <li class="font-medium text-gray-900 dark:text-white" aria-current="page">{tag}</li>
      </ol>
    </nav>

    <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
      Posts tagged <span class="text-[var(--color-accent)]">"{tag}"</span>
    </h1>
    <p class="mt-3 text-gray-600 dark:text-gray-400">
      {posts.length} {posts.length === 1 ? 'article' : 'articles'}
    </p>

    <div class="mt-10 grid gap-8 sm:grid-cols-2">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}/`}
          class="group rounded-xl border border-gray-200 bg-white p-6 transition-all hover:border-gray-300 hover:shadow-md dark:border-gray-800 dark:bg-gray-900 dark:hover:border-gray-700"
        >
          <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
            <time datetime={post.data.publishedAt.toISOString()}>
              {post.data.publishedAt.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <span aria-hidden="true">&middot;</span>
            <span>{readingTime(post.body)}</span>
          </div>
          <h2 class="mt-2 text-lg font-semibold text-gray-900 group-hover:text-[var(--color-accent)] dark:text-white dark:group-hover:text-[var(--color-accent-muted)] transition-colors">
            {post.data.title}
          </h2>
          <p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">
            {post.data.description}
          </p>
        </a>
      ))}
    </div>

    <div class="mt-10">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 transition-colors hover:text-[var(--color-accent)] dark:text-gray-400 dark:hover:text-[var(--color-accent-muted)]"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        All posts
      </a>
    </div>
  </div>
</BaseLayout>
