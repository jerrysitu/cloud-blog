---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { getBreadcrumbSchema, getCollectionPageSchema } from '../../data/schemas';

const siteUrl = 'https://cloud-blog.pages.dev';

const now = new Date();
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.publishedAt <= now)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Collect all tags from published posts
const tagCounts = new Map<string, number>();
posts.forEach((post) => {
  post.data.tags?.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const allTags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);

const featuredPost = posts[0];
const regularPosts = posts.slice(1);

function readingTime(body: string | undefined): string {
  if (!body) return '1 min read';
  const words = body.split(/\s+/).length;
  const minutes = Math.max(1, Math.ceil(words / 200));
  return `${minutes} min read`;
}
---

<BaseLayout
  title="Blog - AI Shop Blueprint"
  description="Articles about using AI and LLMs to grow your Etsy and Print-on-Demand business."
  currentPage="blog"
>
  <JsonLd schema={getCollectionPageSchema(`${siteUrl}/blog`)} />
  <JsonLd
    schema={getBreadcrumbSchema([
      { name: 'Home', url: siteUrl },
      { name: 'Blog', url: `${siteUrl}/blog` },
    ])}
  />

  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
    <!-- Header -->
    <div>
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500">
          <li>
            <a href="/" class="transition-colors hover:text-gray-900 dark:hover:text-white">Home</a>
          </li>
          <li aria-hidden="true" class="text-gray-300 dark:text-gray-700">/</li>
          <li class="font-medium text-gray-900 dark:text-white" aria-current="page">Blog</li>
        </ol>
      </nav>

      <h1 class="font-display text-4xl tracking-tight text-gray-900 dark:text-white sm:text-5xl">
        Blog
      </h1>
      <p class="mt-3 max-w-xl text-gray-500 dark:text-gray-400">
        Practical guides on using AI to grow your Etsy and Print-on-Demand business.
      </p>
    </div>

    <!-- Tag Filter -->
    {allTags.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2">
        {allTags.map(([tag]) => (
          <a
            href={`/blog/tags/${tag.toLowerCase().replace(/\s+/g, '-')}/`}
            class="rounded-full border border-gray-200 px-3 py-1 text-xs font-medium text-gray-500 transition-all hover:border-emerald-400 hover:text-emerald-600 dark:border-gray-700 dark:text-gray-400 dark:hover:border-emerald-500/40 dark:hover:text-emerald-400"
          >
            {tag}
          </a>
        ))}
      </div>
    )}

    {posts.length > 0 ? (
      <div class="mt-14 space-y-12">
        {/* Featured Post */}
        {featuredPost && (
          <a
            href={`/blog/${featuredPost.id}/`}
            class="blog-featured group relative block rounded-2xl border border-gray-200 p-8 transition-all hover:border-gray-300 hover:shadow-lg hover:shadow-gray-200/50 sm:p-10 dark:border-gray-800 dark:hover:border-gray-700 dark:hover:shadow-black/20"
          >
            <div class="flex items-center gap-3 text-sm">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-3 py-0.5 text-xs font-semibold text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400">
                Latest
              </span>
              <span class="text-gray-400 dark:text-gray-500">
                <time datetime={featuredPost.data.publishedAt.toISOString()}>
                  {featuredPost.data.publishedAt.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </span>
              <span aria-hidden="true" class="h-1 w-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
              <span class="text-gray-400 dark:text-gray-500">{readingTime(featuredPost.body)}</span>
            </div>

            <h2 class="mt-4 font-display text-2xl leading-tight text-gray-900 transition-colors group-hover:text-emerald-600 sm:text-3xl dark:text-white dark:group-hover:text-emerald-400">
              {featuredPost.data.title}
            </h2>
            <p class="mt-3 max-w-2xl text-gray-500 dark:text-gray-400">
              {featuredPost.data.description}
            </p>

            {featuredPost.data.tags && featuredPost.data.tags.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-2">
                {featuredPost.data.tags.map((tag) => (
                  <span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-500 dark:bg-gray-800 dark:text-gray-400">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 transition-all group-hover:gap-3 dark:text-emerald-400">
              Read article
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </a>
        )}

        {/* Regular Posts Grid */}
        {regularPosts.length > 0 && (
          <div class="grid gap-6 sm:grid-cols-2">
            {regularPosts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="group rounded-2xl border border-gray-200 bg-white p-6 transition-all hover:border-gray-300 hover:shadow-md hover:shadow-gray-200/50 dark:border-gray-800 dark:bg-gray-900/50 dark:hover:border-gray-700 dark:hover:shadow-black/20"
              >
                <div class="flex items-center gap-3 text-xs text-gray-400 dark:text-gray-500">
                  <time datetime={post.data.publishedAt.toISOString()}>
                    {post.data.publishedAt.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                  <span aria-hidden="true" class="h-1 w-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
                  <span>{readingTime(post.body)}</span>
                </div>
                <h2 class="mt-2.5 font-display text-lg leading-snug text-gray-900 transition-colors group-hover:text-emerald-600 dark:text-white dark:group-hover:text-emerald-400">
                  {post.data.title}
                </h2>
                <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
                  {post.data.description}
                </p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-500 dark:bg-gray-800 dark:text-gray-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        )}
      </div>
    ) : (
      <div class="mt-20 rounded-2xl border border-gray-200 bg-white p-16 text-center dark:border-gray-800 dark:bg-gray-900/50">
        <h2 class="font-display text-xl text-gray-900 dark:text-white">Coming Soon</h2>
        <p class="mt-2 text-gray-500 dark:text-gray-400">
          We're working on some great content. Check back soon!
        </p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .blog-featured {
    background: linear-gradient(135deg, rgba(255,255,255,0.9) 0%, rgba(240,253,244,0.4) 100%);
  }
  :global(.dark) .blog-featured {
    background: linear-gradient(135deg, rgba(17,24,39,0.5) 0%, rgba(6,78,59,0.08) 100%);
  }
</style>
