---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { getWebsiteSchema } from '../data/schemas';

const now = new Date();
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.publishedAt <= now)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 6);
---

<BaseLayout
  title="AI Shop Blueprint - AI Strategies for Etsy & POD"
  description="Practical AI strategies for Etsy sellers and Print-on-Demand entrepreneurs. Learn to use LLMs for listings, design, SEO, and automation."
>
  <JsonLd schema={getWebsiteSchema()} />

  <!-- Hero -->
  <section class="hero-gradient relative overflow-hidden">
    <div class="blueprint-grid noise relative">
      <!-- Decorative floating elements -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute -right-20 top-12 h-64 w-64 rounded-full bg-[var(--color-accent)]/5 blur-3xl dark:bg-[var(--color-accent)]/10"></div>
        <div class="absolute -left-10 bottom-0 h-48 w-48 rounded-full bg-purple-500/5 blur-3xl dark:bg-purple-500/10"></div>
        <!-- Blueprint crosshairs -->
        <div class="absolute right-[15%] top-[20%] h-8 w-px bg-[var(--color-accent)]/15 dark:bg-[var(--color-accent)]/25"></div>
        <div class="absolute right-[calc(15%-16px)] top-[calc(20%+16px)] h-px w-8 bg-[var(--color-accent)]/15 dark:bg-[var(--color-accent)]/25"></div>
        <div class="absolute bottom-[25%] left-[10%] h-6 w-px bg-[var(--color-accent)]/10 dark:bg-[var(--color-accent)]/20"></div>
        <div class="absolute bottom-[calc(25%+12px)] left-[calc(10%-12px)] h-px w-6 bg-[var(--color-accent)]/10 dark:bg-[var(--color-accent)]/20"></div>
      </div>

      <div class="relative z-10 mx-auto max-w-5xl px-4 py-24 sm:px-6 sm:py-32 lg:py-36">
        <div class="max-w-2xl">
          <!-- Label -->
          <div class="animate-fade-in-up mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-accent)]/20 bg-[var(--color-accent-light)] px-3.5 py-1.5 text-xs font-semibold uppercase tracking-wider text-[var(--color-accent)] dark:border-[var(--color-accent)]/20 dark:bg-[var(--color-accent)]/10 dark:text-[var(--color-accent-muted)]">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)] dark:bg-[var(--color-accent-muted)]"></span>
            AI × Ecommerce
          </div>

          <h1 class="animate-fade-in-up animate-delay-1 font-display text-5xl leading-[1.1] tracking-tight text-gray-900 dark:text-white sm:text-6xl lg:text-7xl">
            AI Shop <br/>
            <span class="bg-gradient-to-r from-[#4f46e5] to-[#7c3aed] bg-clip-text text-transparent dark:from-[var(--color-accent-muted)] dark:to-purple-400">
              Blueprint
            </span>
          </h1>

          <p class="animate-fade-in-up animate-delay-2 mt-6 max-w-lg text-lg leading-relaxed text-gray-600 dark:text-gray-400">
            Practical strategies for Etsy sellers and Print-on-Demand entrepreneurs.
            Use ChatGPT, Claude, and Midjourney to write better listings,
            create designs, optimize SEO, and automate your shop.
          </p>

          <div class="animate-fade-in-up animate-delay-3 mt-10 flex flex-wrap items-center gap-4">
            <a
              href="/blog"
              class="group inline-flex items-center gap-2.5 rounded-xl bg-[var(--color-accent)] px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition-all hover:bg-[var(--color-accent-hover)] hover:shadow-xl hover:shadow-indigo-500/30 dark:shadow-indigo-500/20 dark:hover:shadow-indigo-500/30"
            >
              Read the Blog
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a
              href="/rss.xml"
              class="inline-flex items-center gap-2 rounded-xl border border-gray-400 bg-white/80 px-5 py-3 text-sm font-medium text-gray-800 backdrop-blur-sm transition-all hover:border-gray-500 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:text-gray-300 dark:hover:border-white/20 dark:hover:bg-white/10"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z"></path>
              </svg>
              Subscribe via RSS
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom edge gradient -->
    <div class="h-px bg-gradient-to-r from-transparent via-[var(--color-accent)]/20 to-transparent"></div>
  </section>

  <!-- Recent Posts -->
  {posts.length > 0 && (
    <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6 sm:py-24">
      <div class="flex items-end justify-between">
        <div>
          <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-accent)] dark:text-[var(--color-accent-muted)]">
            Latest
          </span>
          <h2 class="mt-1 font-display text-3xl tracking-tight text-gray-900 dark:text-white sm:text-4xl">
            Recent Posts
          </h2>
        </div>
        <a
          href="/blog"
          class="group hidden items-center gap-1.5 text-sm font-medium text-gray-500 transition-colors hover:text-[var(--color-accent)] dark:text-gray-400 dark:hover:text-[var(--color-accent-muted)] sm:inline-flex"
        >
          View all
          <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, i) => (
          <a
            href={`/blog/${post.id}/`}
            class:list={[
              "card-elevated accent-bar group relative rounded-2xl p-6 pl-7",
              `animate-fade-in-up animate-delay-${Math.min(i + 1, 4)}`
            ]}
          >
            <time
              datetime={post.data.publishedAt.toISOString()}
              class="text-xs font-medium text-gray-400 dark:text-gray-500"
            >
              {post.data.publishedAt.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
            <h3 class="mt-2.5 font-display text-lg leading-snug text-gray-900 transition-colors group-hover:text-[var(--color-accent)] dark:text-white dark:group-hover:text-[var(--color-accent-muted)]">
              {post.data.title}
            </h3>
            <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              {post.data.description}
            </p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag-pill">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>

      <div class="mt-8 text-center sm:hidden">
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-accent)] dark:text-[var(--color-accent-muted)]"
        >
          View all posts
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </section>
  )}
</BaseLayout>
