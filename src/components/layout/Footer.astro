---
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-gray-200 dark:border-gray-800">
  <div class="bg-gray-50 dark:bg-gray-900/50">
    <div class="mx-auto max-w-5xl px-4 py-14 sm:px-6">
      <div class="grid gap-10 sm:grid-cols-3 sm:gap-8">
        <!-- Brand -->
        <div class="sm:col-span-2">
          <a href="/" class="text-base font-semibold tracking-tight text-gray-900 dark:text-white">
            AI Shop <span class="text-emerald-600 dark:text-emerald-400">Blueprint</span>
          </a>
          <p class="mt-3 max-w-sm text-sm leading-relaxed text-gray-500 dark:text-gray-400">
            Practical AI strategies for Etsy sellers and Print-on-Demand entrepreneurs.
          </p>
        </div>

        <!-- Links -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">
            Navigate
          </h3>
          <nav class="mt-3 flex flex-col gap-2.5">
            <a href="/" class="text-sm text-gray-500 transition-colors hover:text-emerald-600 dark:text-gray-400 dark:hover:text-emerald-400">Home</a>
            <a href="/blog" class="text-sm text-gray-500 transition-colors hover:text-emerald-600 dark:text-gray-400 dark:hover:text-emerald-400">Blog</a>
            <a href="/rss.xml" class="text-sm text-gray-500 transition-colors hover:text-emerald-600 dark:text-gray-400 dark:hover:text-emerald-400">RSS Feed</a>
          </nav>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-gray-200 pt-6 sm:flex-row dark:border-gray-800">
        <p class="text-xs text-gray-400 dark:text-gray-500">
          &copy; {year} AI Shop Blueprint. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
